---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocale, getLocaleData, localizeHref } from '@/data/site';

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
---

<BaseLayout title={copy.pages.blogIndex.title} description={copy.pages.blogIndex.description}>
  <section class="section log-hero">
    <div class="shell log-intro">
      <p class="eyebrow">{copy.pages.blogIndex.eyebrow}</p>
      <h1 class="display log-title">{copy.pages.blogIndex.titleText}</h1>
      <p class="lead">{copy.pages.blogIndex.lead}</p>
    </div>
  </section>

  <section class="section">
    <div class="shell log-table">
      <div class="log-header">
        <span>{copy.pages.blogIndex.dateHeader}</span>
        <span>{copy.pages.blogIndex.subjectHeader}</span>
        <span>{copy.pages.blogIndex.categoryHeader}</span>
      </div>

      {copy.posts.map((post) => (
        <article class="log-row">
          <span class="log-date">{post.date}</span>
          <a class="log-link focus-ring" href={localizeHref(locale, `/blog/${post.slug}`)}>
            <strong>{post.title[locale]}</strong>
            <p>{post.summary[locale]}</p>
          </a>
          <span class="log-category">{post.category[locale]}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section log-footer">
    <div class="shell log-footer__inner">
      <p class="eyebrow">{copy.pages.blogIndex.pageLabel}</p>
      <div class="log-pager">
        <span>{copy.pages.blogIndex.previousLabel}</span>
        <span>{copy.pages.blogIndex.nextLabel}</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .log-hero {
    padding-top: 56px;
  }

  .log-intro {
    max-width: 760px;
    display: grid;
    gap: 18px;
  }

  .log-title {
    max-width: 32rem;
    font-size: clamp(3.6rem, 8vw, 7rem);
  }

  .log-table {
    border-top: 1px solid var(--line);
  }

  .log-header,
  .log-row {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr) 140px;
    gap: 24px;
    align-items: start;
  }

  .log-header {
    padding: 10px 0 16px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--line);
  }

  .log-row {
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
  }

  .log-date,
  .log-category {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 10px;
  }

  .log-link {
    display: grid;
    gap: 10px;
  }

  .log-link strong {
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    line-height: 0.9;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
  }

  .log-link p {
    margin: 0;
    max-width: 30rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .log-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: center;
    border-top: 1px solid var(--line);
    padding-top: 14px;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .log-pager {
    display: flex;
    gap: 18px;
  }

  @media (max-width: 800px) {
    .log-header {
      display: none;
    }

    .log-header,
    .log-row {
      grid-template-columns: 1fr;
    }

    .log-category {
      padding-top: 0;
    }

    .log-footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

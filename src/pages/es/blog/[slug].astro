---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocale, getLocaleData, posts } from '@/data/site';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
const { post } = Astro.props as {
  post: (typeof posts)[number];
};
---

<BaseLayout title={`${post.title[locale]} | ${copy.site.name}`} description={post.summary[locale]}>
  <section class="section article-hero">
    <div class="shell article-grid">
      <div class="article-copy">
        <p class="eyebrow">{post.category[locale]}</p>
        <h1 class="display article-title">{post.title[locale]}</h1>
        <p class="lead">{post.summary[locale]}</p>
      </div>

      <aside class="article-meta">
        <div class="meta-item">
          <span>{copy.pages.blogDetail.date}</span>
          <strong>{post.date}</strong>
        </div>
        <div class="meta-item">
          <span>{copy.pages.blogDetail.readTime}</span>
          <strong>{post.readTime[locale]}</strong>
        </div>
        <div class="meta-item">
          <span>{copy.pages.blogDetail.tags}</span>
          <strong>{post.tags.slice(0, 2).join(' / ')}</strong>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell article-body">
      <article class="article-main">
        <div class="article-section">
          <p class="eyebrow">{copy.pages.blogDetail.overview}</p>
          <p>{post.content[0][locale]}</p>
        </div>

        <div class="article-section">
          <p class="eyebrow">{copy.pages.blogDetail.process}</p>
          <p>{post.content[1][locale]}</p>
        </div>

        <div class="article-section">
          <p class="eyebrow">{copy.pages.blogDetail.outcome}</p>
          <p>{post.content[2][locale]}</p>
        </div>

        <blockquote class="article-quote">
          <p>{copy.pages.blogDetail.quote}</p>
        </blockquote>
      </article>

      <aside class="article-side">
        <div class="side-block">
          <p class="eyebrow">{copy.pages.blogDetail.tags}</p>
          <div class="tag-list">
            {post.tags.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .article-hero {
    padding-top: 56px;
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(240px, 0.85fr);
    gap: 56px;
    align-items: end;
  }

  .article-copy {
    display: grid;
    gap: 20px;
  }

  .article-title {
    max-width: 33rem;
    font-size: clamp(2.85rem, 5.8vw, 5.4rem);
  }

  .article-meta {
    display: grid;
    gap: 14px;
    padding-top: clamp(120px, 12vw, 180px);
  }

  .meta-item {
    padding-top: 14px;
    border-top: 1px solid var(--line);
    display: grid;
    gap: 8px;
  }

  .meta-item span {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .meta-item strong {
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.95;
    font-size: clamp(1.2rem, 1.8vw, 1.7rem);
  }

  .article-body {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(240px, 0.4fr);
    gap: 40px;
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }

  .article-main {
    display: grid;
    gap: 22px;
  }

  .article-section {
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }

  .article-section p:last-child {
    margin: 10px 0 0;
    max-width: 32rem;
    line-height: 1.8;
    color: var(--muted);
  }

  .article-quote {
    margin: 4px 0 0;
    background: var(--surface-soft);
    padding: 24px;
    border-left: 2px solid var(--ink);
  }

  .article-quote p {
    margin: 0;
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.94;
    font-size: clamp(1.6rem, 3vw, 2.6rem);
  }

  .article-side {
    align-self: start;
  }

  .side-block {
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
  }

  @media (max-width: 960px) {
    .article-grid,
    .article-body {
      grid-template-columns: 1fr;
    }

    .article-meta {
      padding-top: 12px;
    }

    .article-title {
      max-width: 33rem;
      font-size: clamp(2.65rem, 11vw, 4.35rem);
    }
  }
</style>

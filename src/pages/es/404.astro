---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocale, getLocaleData } from '@/data/site';

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
---

<BaseLayout title={copy.pages.notFound.title} description={copy.pages.notFound.description}>
  <section class="section">
    <div class="shell">
      <div class="error-shell">
        <p class="eyebrow">{copy.pages.notFound.eyebrow}</p>
        <h1 class="display error-title">{copy.pages.notFound.titleText}</h1>
        <p class="lead">{copy.pages.notFound.lead}</p>
        <a class="button focus-ring" href={locale === 'en' ? '/' : '/es'}>{copy.pages.notFound.cta}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-shell {
    display: grid;
    gap: 20px;
    max-width: 720px;
    padding-top: 18px;
  }

  .error-title {
    font-size: clamp(3.8rem, 8vw, 7rem);
    max-width: 28rem;
  }
</style>

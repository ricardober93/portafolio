---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getLocale, getLocaleData, localizeHref } from "@/data/site";

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
---

<BaseLayout
    title={copy.pages.projectsIndex.title}
    description={copy.pages.projectsIndex.description}
>
    <section class="section archive-hero">
        <div class="shell archive-intro">
            <p class="eyebrow">{copy.pages.projectsIndex.eyebrow}</p>
            <h1 class="display archive-title">
                {copy.pages.projectsIndex.titleText}
            </h1>
            <p class="lead">{copy.pages.projectsIndex.lead}</p>
        </div>
    </section>

    <section class="section">
        <div class="shell">
            <div class="archive-grid">
                {
                    copy.projects.map((project) => (
                        <ProjectCard project={project} locale={locale} />
                    ))
                }
            </div>
        </div>
    </section>

    <section class="section archive-footer">
        <div class="shell archive-footer__inner">
            <SectionHeading
                eyebrow={copy.pages.projectsIndex.manifestoEyebrow}
                title={copy.pages.projectsIndex.manifestoTitle}
                lead={copy.pages.projectsIndex.manifestoLead}
            />

            <div class="archive-callout">
                <p class="eyebrow">{copy.pages.projectsIndex.ctaEyebrow}</p>
                <h2 class="display">{copy.pages.projectsIndex.ctaTitle}</h2>
                <a
                    class="button focus-ring"
                    href={localizeHref(locale, "/contact")}
                >
                    {copy.pages.projectsIndex.ctaPrimary}
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .archive-hero {
        padding-top: 56px;
    }

    .archive-intro {
        max-width: 820px;
        display: grid;
        gap: 18px;
    }

    .archive-title {
        max-width: 32rem;
        font-size: clamp(3.6rem, 8vw, 7rem);
    }

    .archive-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0;
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
    }

    .archive-footer__inner {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(260px, 0.75fr);
        gap: 40px;
        align-items: end;
    }

    .archive-footer__inner :global(.section-heading) {
        max-width: 620px;
    }

    .archive-callout {
        padding-top: 18px;
        border-top: 1px solid var(--line);
        display: grid;
        justify-items: start;
        gap: 14px;
    }

    .archive-callout .display {
        font-size: clamp(2.05rem, 4.4vw, 3.9rem);
        max-width: 30rem;
    }

    @media (max-width: 960px) {
        .archive-grid,
        .archive-footer__inner {
            grid-template-columns: 1fr;
        }
    }
</style>

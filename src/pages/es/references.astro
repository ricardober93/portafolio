---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { getLocale, getLocaleData } from '@/data/site';

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
---

<BaseLayout title={copy.pages.references.title} description={copy.pages.references.description}>
  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow={copy.pages.references.eyebrow}
        title={copy.pages.references.titleText}
        lead={copy.pages.references.lead}
      />

      <div class="refs-grid">
        {copy.referenceSlides.map((item) => (
          <article class="ref-card panel">
            <img src={`/reference/${item.slug}.png`} alt={item.title[locale]} loading="lazy" />
            <div class="ref-copy">
              <p class="eyebrow">{item.title[locale]}</p>
              <p>{item.caption[locale]}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .refs-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }
  .ref-card {
    overflow: hidden;
  }
  .ref-card img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
  }
  .ref-copy {
    padding: 18px 20px 20px;
  }
  .ref-copy p:last-child {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.6;
  }
  @media (max-width: 800px) {
    .refs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { getLocale, getLocaleData } from '@/data/site';

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
---

<BaseLayout title={copy.pages.about.title} description={copy.pages.about.description}>
  <section class="section about-hero">
    <div class="shell about-grid">
      <div class="about-copy">
        <p class="eyebrow">{copy.pages.about.eyebrow}</p>
        <h1 class="display about-title">{copy.pages.about.titleText}</h1>
        <p class="lead">{copy.pages.about.lead}</p>
      </div>

      <aside class="about-aside">
        <div class="about-panel">
          <p class="eyebrow">{copy.pages.about.profileEyebrow}</p>
          <p>{copy.pages.about.profile}</p>
        </div>

        <div class="about-panel">
          <p class="eyebrow">{copy.pages.about.contactEyebrow}</p>
          <a class="about-link focus-ring" href={`https://wa.me/${copy.site.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noreferrer">
            {copy.pages.contact.whatsapp} {copy.site.whatsapp}
          </a>
          <a class="about-link focus-ring" href="https://www.linkedin.com/in/ricardotellez7/" target="_blank" rel="noreferrer">
            {copy.pages.contact.linkedin}
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow={copy.pages.about.experienceEyebrow}
        title={copy.pages.about.experienceTitle}
        lead={copy.pages.about.experienceLead}
      />

      <div class="experience-list">
        {copy.experience.map((item, index) => (
          <article class="experience-row">
            <div class="experience-meta">
              <span class="experience-index">0{index + 1}</span>
              <div>
                <h3>{item.company[locale]}</h3>
                <p class="experience-role">{item.role[locale]}</p>
                <p class="experience-period">{item.period[locale]}</p>
              </div>
            </div>
            <p class="experience-summary">{item.summary[locale]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split-layout">
      <SectionHeading
        eyebrow={copy.pages.about.workingPrinciplesEyebrow}
        title={copy.pages.about.workingPrinciplesTitle}
        lead={copy.pages.about.workingPrinciplesLead}
      />

      <ul class="principles-list">
        {copy.principles.map((item, index) => (
          <li class="principle-row">
            <span class="principle-index">0{index + 1}</span>
            <p>{item}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding-top: 56px;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: 56px;
    align-items: start;
  }

  .about-copy {
    display: grid;
    gap: 20px;
  }

  .about-title {
    max-width: 31rem;
    font-size: clamp(3.3rem, 7vw, 6.6rem);
  }

  .about-aside {
    display: grid;
    gap: 16px;
    padding-top: clamp(120px, 12vw, 170px);
  }

  .about-panel {
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .about-panel p {
    margin: 10px 0 0;
    line-height: 1.75;
    color: var(--muted);
  }

  .about-link {
    display: block;
    margin-top: 12px;
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    font-size: clamp(1.4rem, 2vw, 2rem);
    line-height: 0.95;
  }

  .about-link + .about-link {
    margin-top: 10px;
  }

  .experience-list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .experience-row {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }

  .experience-meta {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .experience-index {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 8px;
  }

  .experience-meta h3 {
    margin: 0 0 6px;
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    line-height: 0.9;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
  }

  .experience-role,
  .experience-period,
  .experience-summary {
    margin: 0;
    line-height: 1.7;
    color: var(--muted);
  }

  .experience-role {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .experience-period {
    font-size: 0.92rem;
  }

  .split-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 40px;
  }

  .principles-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .principle-row {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 18px;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }

  .principle-index {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 6px;
  }

  .principle-row p {
    margin: 0;
    max-width: 26rem;
    line-height: 1.7;
  }

  @media (max-width: 960px) {
    .about-grid,
    .split-layout {
      grid-template-columns: 1fr;
    }

    .about-aside {
      padding-top: 12px;
    }

    .about-title {
      max-width: 30rem;
      font-size: clamp(3rem, 13vw, 5rem);
    }

    .experience-row {
      grid-template-columns: 1fr;
    }
  }
</style>

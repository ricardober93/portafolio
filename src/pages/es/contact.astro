---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocale, getLocaleData } from '@/data/site';

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
---

<BaseLayout title={copy.pages.contact.title} description={copy.pages.contact.description}>
  <section class="section contact-hero">
    <div class="shell contact-grid">
      <div class="contact-copy">
        <p class="eyebrow">{copy.pages.contact.eyebrow}</p>
        <h1 class="display contact-title">{copy.pages.contact.titleText}</h1>
        <p class="lead">{copy.pages.contact.lead}</p>
      </div>

      <div class="contact-actions">
        <a class="button focus-ring" href={`https://wa.me/${copy.site.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noreferrer">
          {copy.pages.contact.whatsapp}
        </a>
        <a class="button secondary focus-ring" href={`https://t.me/${copy.site.telegram.replace(/^@/, '')}`} target="_blank" rel="noreferrer">
          {copy.pages.contact.telegram}
        </a>
        <a class="button secondary focus-ring" href="https://www.linkedin.com/in/ricardotellez7/" target="_blank" rel="noreferrer">
          {copy.pages.contact.linkedin}
        </a>
        <div class="contact-meta">
          <span>{copy.site.location}</span>
          <span>{copy.pages.contact.availability}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell contact-detail">
      <div class="detail-block">
        <p class="eyebrow">{copy.pages.contact.worksWellEyebrow}</p>
        <p>{copy.pages.contact.worksWell}</p>
      </div>

      <div class="detail-block">
        <p class="eyebrow">{copy.pages.contact.responseEyebrow}</p>
        <p>{copy.pages.contact.response}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 56px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.9fr);
    gap: 56px;
    align-items: end;
  }

  .contact-copy {
    display: grid;
    gap: 20px;
  }

  .contact-title {
    max-width: 35rem;
    font-size: clamp(2.85rem, 5.8vw, 5.45rem);
  }

  .contact-actions {
    display: grid;
    gap: 12px;
    justify-items: start;
    padding-top: clamp(120px, 12vw, 180px);
  }

  .contact-actions .button {
    width: fit-content;
  }

  .contact-meta {
    display: grid;
    gap: 8px;
    padding-top: 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .contact-detail {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }

  .detail-block {
    padding-top: 10px;
    border-top: 1px solid var(--line);
  }

  .detail-block p:last-child {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.75;
    max-width: 20rem;
  }

  @media (max-width: 960px) {
    .contact-grid,
    .contact-detail {
      grid-template-columns: 1fr;
    }

    .contact-actions {
      padding-top: 12px;
    }

    .contact-title {
      max-width: 33rem;
      font-size: clamp(2.65rem, 11vw, 4.4rem);
    }
  }
</style>

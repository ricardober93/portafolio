---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { getLocale, getLocaleData, localizeHref } from '@/data/site';

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
---

<BaseLayout title={copy.pages.home.title} description={copy.pages.home.description}>
  <section class="section hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{copy.pages.home.eyebrow}</p>
        <h1 class="display hero-title">{copy.site.headline}</h1>
        <p class="lead hero-lead">{copy.site.subheadline}</p>

        <div class="hero-actions">
          <a class="button focus-ring" href={localizeHref(locale, '/projects')}>
            {locale === 'en' ? 'Projects' : 'Proyectos'}
          </a>
          <a class="button secondary focus-ring" href={localizeHref(locale, '/contact')}>
            {locale === 'en' ? 'Contact' : 'Contacto'}
          </a>
        </div>
      </div>

      <aside class="hero-side">
        <div class="hero-note">
          <p class="eyebrow">{copy.pages.home.currentFocusLabel}</p>
          <p>{copy.pages.home.currentFocus}</p>
        </div>

        <div class="hero-note hero-note--line">
          <p class="eyebrow">{copy.pages.home.baseLabel}</p>
          <p>{copy.pages.home.base}</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-soft">
    <div class="shell split-layout">
      <SectionHeading
        eyebrow={copy.pages.home.coreExpertiseEyebrow}
        title={copy.pages.home.coreExpertiseTitle}
        lead={copy.pages.home.coreExpertiseLead}
      />

      <div class="expertise-list">
        {copy.expertise.map((item, index) => (
          <article class="expertise-row">
            <span class="expertise-index">0{index + 1}</span>
            <div class="expertise-copy">
              <h3>{item.title[locale]}</h3>
              <p>{item.description[locale]}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow={copy.pages.home.experienceEyebrow}
        title={copy.pages.home.experienceTitle}
        lead={copy.pages.home.experienceLead}
      />

      <div class="experience-list">
        {copy.experience.map((item, index) => (
          <article class="experience-row">
            <div class="experience-meta">
              <span class="experience-index">0{index + 1}</span>
              <div>
                <h3>{item.company[locale]}</h3>
                <p class="experience-role">{item.role[locale]}</p>
                <p class="experience-period">{item.period[locale]}</p>
              </div>
            </div>
            <p class="experience-summary">{item.summary[locale]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading
        eyebrow={copy.pages.home.stackEyebrow}
        title={copy.pages.home.stackTitle}
        lead={copy.pages.home.stackLead}
      />

      <div class="stack-grid">
        {copy.stackSections.map((section) => (
          <article class="stack-column">
            <p class="stack-label">{section.title[locale]}</p>
            <ul class="stack-list">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band section">
    <div class="shell cta-band__inner">
      <div>
        <p class="eyebrow">{copy.pages.home.ctaEyebrow}</p>
        <h2 class="display">{copy.pages.home.ctaTitle}</h2>
      </div>

      <div class="cta-actions">
        <a class="button focus-ring" href={localizeHref(locale, '/contact')}>
          {copy.pages.home.ctaPrimary}
        </a>
        <a
          class="button secondary focus-ring"
          href="https://www.linkedin.com/in/ricardotellez7/"
          target="_blank"
          rel="noreferrer"
        >
          {copy.pages.home.ctaSecondary}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 64px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.28fr) minmax(240px, 0.72fr);
    gap: 60px;
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: 22px;
    padding-top: 12px;
    padding-right: clamp(8px, 2vw, 32px);
  }

  .hero-title {
    max-width: 30rem;
    font-size: clamp(3.2rem, 6.8vw, 6.5rem);
  }

  .hero-lead {
    max-width: 22rem;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-side {
    display: grid;
    gap: 20px;
    align-content: start;
    padding-top: clamp(110px, 11vw, 160px);
  }

  .hero-note {
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .hero-note p:last-child {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.7;
    max-width: 16rem;
  }

  .hero-note--line {
    display: grid;
    gap: 0;
  }

  .split-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 48px;
  }

  .expertise-list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .expertise-row {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 18px;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }

  .expertise-index {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 8px;
  }

  .expertise-copy h3 {
    margin: 0 0 8px;
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    line-height: 0.9;
  }

  .expertise-copy p {
    margin: 0;
    max-width: 28rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .experience-list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .experience-row {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }

  .experience-meta {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .experience-index {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 8px;
  }

  .experience-meta h3 {
    margin: 0 0 6px;
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    line-height: 0.9;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
  }

  .experience-role,
  .experience-period,
  .experience-summary {
    margin: 0;
    line-height: 1.7;
    color: var(--muted);
  }

  .experience-role {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .experience-period {
    font-size: 0.92rem;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
    border-top: 1px solid var(--line);
  }

  .stack-column {
    padding-top: 18px;
  }

  .stack-label {
    margin: 0 0 20px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .stack-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .stack-list li {
    padding-top: 10px;
    border-top: 1px solid var(--line);
    font-family: 'Archivo Black', sans-serif;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.95;
    font-size: clamp(1.1rem, 1.45vw, 1.55rem);
  }

  .cta-band {
    background: var(--ink);
    color: white;
    padding: clamp(108px, 9vw, 144px) 1rem;
  }

  .cta-band__inner {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
  }

  .cta-band .eyebrow,
  .cta-band .muted {
    color: rgba(255, 255, 255, 0.64);
  }

  .cta-band .display {
    max-width: 39rem;
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
  }

  .cta-band .button {
    border-color: white;
    background: white;
    color: var(--ink);
  }

  .cta-band .button.secondary {
    background: transparent;
    color: white;
  }

  .cta-band .button.secondary:hover {
    background: white;
    color: var(--ink);
  }

  @media (max-width: 960px) {
    .hero-grid,
    .split-layout,
    .cta-band__inner {
      grid-template-columns: 1fr;
      display: grid;
    }

    .hero-side {
      padding-top: 16px;
    }

    .hero-copy {
      padding-right: 0;
    }

    .stack-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .experience-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 24px;
    }

    .cta-band {
      padding: 80px 0;
    }

    .hero-title {
      max-width: 32rem;
      font-size: clamp(3.1rem, 14.5vw, 5.1rem);
    }

    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

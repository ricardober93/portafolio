---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projects, site } from '@/data/site';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.title} | ${site.name}`} description={project.description}>
  <section class="section">
    <div class="shell project-hero panel">
      <div class="project-meta">
        <p class="eyebrow">{project.category}</p>
        <h1 class="display">{project.title}</h1>
        <p class="lead">{project.summary}</p>
      </div>

      <div class="project-badges">
        <div class="badge">
          <span>Year</span>
          <strong>{project.year}</strong>
        </div>
        <div class="badge">
          <span>Status</span>
          <strong>{project.status}</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell project-detail">
      <article class="detail-card panel">
        <p class="eyebrow">The challenge</p>
        <p>{project.challenge}</p>
      </article>
      <article class="detail-card panel">
        <p class="eyebrow">The solution</p>
        <p>{project.solution}</p>
      </article>
      <article class="detail-card panel">
        <p class="eyebrow">The impact</p>
        <p>{project.impact}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="shell project-stack panel">
      <div>
        <p class="eyebrow">Stack</p>
        <div class="stack-list">
          {project.stack.map((item) => (
            <span class="chip">{item}</span>
          ))}
        </div>
      </div>
      <div class="project-links">
        {project.links.map((link) => (
          <a class="button focus-ring" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .project-hero {
    padding: 36px;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.76)),
      radial-gradient(circle at top right, rgba(17, 17, 17, 0.08), transparent 34%);
  }
  .project-meta {
    max-width: 760px;
  }
  .project-meta h1 {
    font-size: clamp(4rem, 10vw, 8.5rem);
    margin: 10px 0 14px;
    max-width: 11ch;
  }
  .project-badges {
    display: grid;
    gap: 12px;
    min-width: 220px;
  }
  .badge {
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.7);
    display: grid;
    gap: 4px;
  }
  .badge span {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .badge strong {
    font-size: 1rem;
  }
  .project-detail {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .detail-card {
    padding: 24px;
  }
  .detail-card p:last-child {
    margin: 12px 0 0;
    line-height: 1.75;
    color: var(--muted);
  }
  .project-stack {
    padding: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
  }
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  @media (max-width: 900px) {
    .project-hero,
    .project-stack {
      flex-direction: column;
      align-items: start;
    }
    .project-detail {
      grid-template-columns: 1fr;
    }
  }
</style>

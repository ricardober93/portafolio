---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocale, getLocaleData, localizeHref, projects } from "@/data/site";

export function getStaticPaths() {
    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const locale = getLocale(Astro.currentLocale);
const copy = getLocaleData(locale);
const { project } = Astro.props as {
    project: (typeof projects)[number];
};
const projectTitleLines = project.title[locale].split(" ");
const currentIndex = projects.findIndex((item) => item.slug === project.slug);
const previousProject =
    projects[(currentIndex - 1 + projects.length) % projects.length];
const nextProject = projects[(currentIndex + 1) % projects.length];
---

<BaseLayout
    title={`${project.title[locale]} | ${copy.site.name}`}
    description={project.description[locale]}
>
    <section class="section project-hero">
        <div class="shell project-hero__inner">
            <div class="project-copy">
                <p class="eyebrow">{project.category[locale]}</p>
                <h1
                    class="display project-title"
                    aria-label={project.title[locale]}
                >
                    {
                        projectTitleLines.map((line) => (
                            <span class="project-title__line">{line}</span>
                        ))
                    }
                </h1>
                <p class="lead">{project.summary[locale]}</p>
            </div>

            <aside class="project-meta" aria-label="Project metadata">
                <div class="meta-item">
                    <span>{copy.pages.projectDetail.year}</span>
                    <strong>{project.year}</strong>
                </div>
                <div class="meta-item">
                    <span>{copy.pages.projectDetail.status}</span>
                    <strong>{project.status[locale]}</strong>
                </div>
                <div class="meta-item">
                    <span>{copy.pages.projectDetail.stack}</span>
                    <strong>{project.stack.slice(0, 2).join(" / ")}</strong>
                </div>
            </aside>
        </div>
    </section>

    <section class="section">
        <div class="shell project-body">
            <div class="project-intro">
                <p class="eyebrow">{copy.pages.projectDetail.challenge}</p>
                <p>{project.challenge[locale]}</p>
            </div>

            <div class="project-sections">
                <article class="project-section">
                    <p class="eyebrow">
                        {copy.pages.projectDetail.architecture}
                    </p>
                    <p>{project.solution[locale]}</p>
                </article>
                <article class="project-section">
                    <p class="eyebrow">{copy.pages.projectDetail.results}</p>
                    <p>{project.impact[locale]}</p>
                </article>
                <article class="project-quote">
                    <p>{copy.pages.projectDetail.quote}</p>
                </article>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="shell project-footer">
            <div class="project-stack">
                <p class="eyebrow">{copy.pages.projectDetail.stack}</p>
                <div class="stack-list">
                    {
                        project.stack.map((item) => (
                            <span class="chip">{item}</span>
                        ))
                    }
                </div>
            </div>

            <div class="project-links">
                <p class="eyebrow">{copy.pages.projectDetail.links}</p>
                <div class="link-list">
                    {
                        project.links.map((link) => (
                            <a
                                class="button focus-ring"
                                href={link.href}
                                target={
                                    link.href.startsWith("http")
                                        ? "_blank"
                                        : undefined
                                }
                                rel={
                                    link.href.startsWith("http")
                                        ? "noreferrer"
                                        : undefined
                                }
                            >
                                {link.label[locale]}
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="section project-nav">
        <div class="shell project-nav__inner">
            <a
                class="project-nav-link project-nav-link--prev focus-ring"
                href={localizeHref(locale, `/projects/${previousProject.slug}`)}
            >
                <span class="eyebrow">{copy.pages.projectDetail.previous}</span>
                <strong>{previousProject.title[locale]}</strong>
                <span class="nav-arrow" aria-hidden="true">←</span>
            </a>
            <a
                class="project-nav-link project-nav-link--next focus-ring"
                href={localizeHref(locale, `/projects/${nextProject.slug}`)}
            >
                <span class="eyebrow">{copy.pages.projectDetail.next}</span>
                <strong>{nextProject.title[locale]}</strong>
                <span class="nav-arrow" aria-hidden="true">→</span>
            </a>
        </div>
    </section>
</BaseLayout>

<style>
    .project-hero {
        padding-top: 56px;
    }

    .project-hero__inner {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        column-gap: 24px;
        row-gap: 18px;
        align-items: start;
        min-width: 0;
    }

    .project-copy {
        display: grid;
        gap: 20px;
        grid-column: 1 / span 6;
        min-width: 0;
    }

    .project-title {
        display: grid;
        gap: 0;
        max-width: none;
        font-size: clamp(3.4rem, 7vw, 7rem);
        letter-spacing: -0.09em;
        min-width: 0;
    }

    .project-title__line {
        display: block;
        line-height: 0.88;
    }

    .project-meta {
        display: grid;
        gap: 14px;
        grid-column: 9 / -1;
        padding-left: 24px;
        border-left: 1px solid var(--line);
        align-self: start;
        min-width: 0;
    }

    .meta-item {
        padding-top: 14px;
        border-top: 1px solid var(--line);
        display: grid;
        gap: 8px;
    }

    .meta-item span {
        font-family: "IBM Plex Mono", monospace;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .meta-item strong {
        font-family: "Archivo Black", sans-serif;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        line-height: 0.95;
        font-size: clamp(1.2rem, 1.8vw, 1.8rem);
        overflow-wrap: anywhere;
    }

    .project-body {
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
        gap: 32px 40px;
        align-items: start;
        border-top: 1px solid var(--line);
        padding-top: 24px;
        min-width: 0;
    }

    .project-intro {
        padding-top: 10px;
        border-top: 1px solid var(--line);
        min-width: 0;
    }

    .project-intro p:last-child {
        margin: 10px 0 0;
        color: var(--muted);
        line-height: 1.8;
        max-width: 22rem;
        overflow-wrap: anywhere;
    }

    .project-sections {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
        min-width: 0;
    }

    .project-section,
    .project-quote {
        padding-top: 16px;
        border-top: 1px solid var(--line);
        min-width: 0;
    }

    .project-section p:last-child {
        margin: 10px 0 0;
        color: var(--muted);
        line-height: 1.75;
        overflow-wrap: anywhere;
    }

    .project-quote {
        grid-column: 1 / -1;
        background: var(--surface-soft);
        padding: 22px;
    }

    .project-quote p {
        margin: 0;
        font-family: "Archivo Black", sans-serif;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        line-height: 0.94;
        font-size: clamp(1.7rem, 3vw, 2.7rem);
        overflow-wrap: anywhere;
    }

    .project-footer {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 40px;
        border-top: 1px solid var(--line);
        padding-top: 24px;
        min-width: 0;
    }

    .stack-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 12px;
        min-width: 0;
    }

    .project-links {
        display: grid;
        gap: 12px;
        align-content: start;
        min-width: 0;
    }

    .link-list {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        min-width: 0;
    }

    .project-nav__inner {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        min-width: 0;
    }

    .project-nav-link {
        display: grid;
        gap: 10px;
        padding: 22px 0 24px;
        min-width: 0;
    }

    .project-nav-link--prev {
        padding-right: 24px;
        border-right: 1px solid var(--line);
        justify-items: start;
    }

    .project-nav-link--next {
        padding-left: 24px;
        justify-items: end;
        text-align: right;
    }

    .project-nav-link strong {
        font-family: "Archivo Black", sans-serif;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        line-height: 0.92;
        font-size: clamp(1.4rem, 2.2vw, 2rem);
        overflow-wrap: anywhere;
    }

    .nav-arrow {
        font-family: "IBM Plex Mono", monospace;
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
    }

    @media (max-width: 960px) {
        .project-body,
        .project-footer,
        .project-nav__inner,
        .project-sections {
            grid-template-columns: 1fr;
        }

        .project-hero__inner {
            grid-template-columns: 1fr;
        }

        .project-copy,
        .project-meta {
            grid-column: auto;
            padding-left: 0;
            border-left: 0;
        }

        .project-title {
            font-size: clamp(3rem, 13vw, 5.2rem);
            letter-spacing: -0.07em;
        }

        .project-meta,
        .project-links {
            padding-left: 0;
        }

        .project-nav-link--prev {
            border-right: 0;
            border-bottom: 1px solid var(--line);
            padding-right: 0;
        }

        .project-nav-link--next {
            padding-left: 0;
            text-align: left;
            justify-items: start;
        }
    }
</style>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 | Ricardo Tellez" description="Página no encontrada.">
  <section class="section">
    <div class="shell">
      <div class="panel" style="padding: 40px;">
        <p class="eyebrow">404</p>
        <h1 class="display" style="font-size: clamp(4rem, 10vw, 9rem);">Page not found</h1>
        <p class="lead">La ruta no existe. Vuelve al inicio para seguir explorando el portafolio.</p>
        <div style="margin-top: 24px;">
          <a class="button focus-ring" href="/">Volver al inicio</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

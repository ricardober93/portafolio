---
const { eyebrow, title, lead, align = 'left', level = 2 } = Astro.props;
const HeadingTag = level === 1 ? 'h1' : 'h2';
---

<header class={`section-heading ${align}`}>
  <p class="eyebrow">{eyebrow}</p>
  <HeadingTag class="display">{title}</HeadingTag>
  {lead && <p class="lead">{lead}</p>}
</header>

<style>
  .section-heading {
    display: grid;
    gap: 12px;
    max-width: 700px;
    margin-bottom: 28px;
  }
  .section-heading.center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  .display {
    font-size: clamp(2.4rem, 5vw, 4.8rem);
  }
</style>

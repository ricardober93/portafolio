---
const { eyebrow, title, lead, align = 'left' } = Astro.props;
---

<header class={`section-heading ${align}`}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="display">{title}</h2>
  {lead && <p class="lead">{lead}</p>}
</header>

<style>
  .section-heading {
    display: grid;
    gap: 12px;
    max-width: 720px;
    margin-bottom: 32px;
  }
  .section-heading.center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }
  .display {
    font-size: clamp(2.8rem, 7vw, 6.3rem);
  }
</style>
